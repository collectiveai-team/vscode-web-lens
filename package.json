{
  "name": "web-lens",
  "displayName": "Web Lens Debug",
  "description": "Embedded browser for sending page context to AI coding agents",
  "version": "0.2.14",
  "publisher": "collectiveai-team",
  "icon": "media/logo/weblens-logo.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/collectiveai-team/vscode-web-lens"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onCommand:webLens.open",
    "onWebviewPanel:webLens"
  ],
  "contributes": {
    "commands": [
      {
        "command": "webLens.open",
        "title": "Web Lens: Open"
      },
      {
        "command": "webLens.openUrl",
        "title": "Web Lens: Open URL"
      },
      {
        "command": "webLens.inspect",
        "title": "Web Lens: Inspect Element"
      },
      {
        "command": "webLens.addElement",
        "title": "Web Lens: Add Element to Chat"
      },
      {
        "command": "webLens.addLogs",
        "title": "Web Lens: Add Logs to Chat"
      },
      {
        "command": "webLens.screenshot",
        "title": "Web Lens: Screenshot"
      },
      {
        "command": "webLens.showLogs",
        "title": "Web Lens: Show Logs"
      },
      {
        "command": "webLens.record",
        "title": "Web Lens: Toggle Recording"
      }
    ],
    "configuration": {
      "title": "Web Lens",
      "properties": {
        "webLens.backend": {
          "type": "string",
          "default": "clipboard",
          "enum": [
            "opencode",
            "openchamber",
            "codex",
            "claudecode",
            "clipboard"
          ],
          "description": "Active backend for delivering context to AI agent"
        },
        "webLens.defaultUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "URL loaded when browser panel opens"
        },
        "webLens.screenshotFormat": {
          "type": "string",
          "default": "png",
          "enum": [
            "png",
            "jpeg"
          ],
          "description": "Screenshot image format"
        },
        "webLens.screenshotQuality": {
          "type": "number",
          "default": 0.9,
          "minimum": 0.1,
          "maximum": 1,
          "description": "JPEG quality (0-1), ignored for PNG"
        },
        "webLens.contextDirectory": {
          "type": "string",
          "default": ".tmp",
          "description": "Directory for context files (screenshots and element data). Relative paths resolve from workspace root. Absolute paths used as-is."
        },
        "webLens.storeCookies": {
          "type": "boolean",
          "default": false,
          "description": "When enabled, cookies are captured from proxied sites and replayed across panel sessions. Stored securely in VS Code's encrypted secret storage.",
          "scope": "resource"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.js",
    "dev:standalone": "node esbuild.config.js && node out/standalone/server.js",
    "build:prod": "node esbuild.config.js --production",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.webview.json",
    "package": "npm run build:prod && vsce package",
    "publish": "npm run build:prod && vsce publish",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vscode-test",
    "lint": "eslint src/"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^8.57.0",
    "jsdom": "^29.0.2",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "html2canvas": "^1.4.1"
  }
}